{
  "name": "forensic-crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode github-pages",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixture:kirk": "node scripts/build-charlie-kirk-pilot.mjs",
    "fixture:good": "node scripts/build-renee-good-pilot.mjs",
    "fixture:vessels": "node scripts/build-southern-spear-vessels-pilot.mjs",
    "fixture:enhance:apollo": "node scripts/enhance-package-v2.mjs fixtures/pilots/apollo-11-landing/forensic-package.json",
    "fixture:enhance:kirk": "node scripts/enhance-package-v2.mjs fixtures/pilots/charlie-kirk-assassination/forensic-package.json",
    "fixture:enhance:good": "node scripts/enhance-package-v2.mjs fixtures/pilots/renee-good-killing/forensic-package.json",
    "fixture:enhance:vessels": "node scripts/enhance-package-v2.mjs fixtures/pilots/southern-spear-vessel-strikes/forensic-package.json",
    "fixture:scenes": "node scripts/spatial/enhance-scenes.mjs",
    "fixture:all": "pnpm fixture:kirk && pnpm fixture:good && pnpm fixture:vessels && pnpm fixture:scenes && pnpm fixture:enhance:apollo && pnpm fixture:enhance:kirk && pnpm fixture:enhance:good && pnpm fixture:enhance:vessels",
    "manifest:sign:all": "node scripts/sign-manifest.mjs fixtures/pilots/apollo-11-landing/manifest.json && node scripts/sign-manifest.mjs fixtures/pilots/charlie-kirk-assassination/manifest.json && node scripts/sign-manifest.mjs fixtures/pilots/renee-good-killing/manifest.json && node scripts/sign-manifest.mjs fixtures/pilots/southern-spear-vessel-strikes/manifest.json",
    "manifest:verify:all": "node scripts/verify-manifest.mjs fixtures/pilots/apollo-11-landing/manifest.json && node scripts/verify-manifest.mjs fixtures/pilots/charlie-kirk-assassination/manifest.json && node scripts/verify-manifest.mjs fixtures/pilots/renee-good-killing/manifest.json && node scripts/verify-manifest.mjs fixtures/pilots/southern-spear-vessel-strikes/manifest.json",
    "audit:package": "node scripts/audit-package.mjs fixtures/pilots/apollo-11-landing/forensic-package.json",
    "audit:kirk": "node scripts/audit-package.mjs fixtures/pilots/charlie-kirk-assassination/forensic-package.json",
    "audit:good": "node scripts/audit-package.mjs fixtures/pilots/renee-good-killing/forensic-package.json",
    "audit:vessels": "node scripts/audit-package.mjs fixtures/pilots/southern-spear-vessel-strikes/forensic-package.json",
    "source:check": "node scripts/check-source-links.mjs fixtures/pilots/apollo-11-landing/forensic-package.json",
    "source:kirk": "node scripts/check-source-links.mjs fixtures/pilots/charlie-kirk-assassination/forensic-package.json",
    "source:good": "node scripts/check-source-links.mjs fixtures/pilots/renee-good-killing/forensic-package.json",
    "source:vessels": "node scripts/check-source-links.mjs fixtures/pilots/southern-spear-vessel-strikes/forensic-package.json",
    "fixture:seal": "node scripts/seal-audit-log.mjs fixtures/pilots/apollo-11-landing/forensic-package.json",
    "import:pilot": "node scripts/import-package.mjs fixtures/pilots/apollo-11-landing/forensic-package.json tmp/imports/apollo-11-landing.json",
    "export:pilot": "node scripts/export-package.mjs fixtures/pilots/apollo-11-landing/forensic-package.json tmp/exports/apollo-11-landing",
    "report:pilot": "node scripts/reporting/export-report-v2.mjs fixtures/pilots/apollo-11-landing/forensic-package.json output/reports/APOLLO_11_LANDING_AUDIT.md",
    "report:kirk": "node scripts/reporting/export-report-v2.mjs fixtures/pilots/charlie-kirk-assassination/forensic-package.json output/reports/CHARLIE_KIRK_ASSASSINATION_FIRST_PASS.md",
    "report:good": "node scripts/reporting/export-report-v2.mjs fixtures/pilots/renee-good-killing/forensic-package.json output/reports/RENEE_GOOD_KILLING_FIRST_PASS.md",
    "report:vessels": "node scripts/reporting/export-report-v2.mjs fixtures/pilots/southern-spear-vessel-strikes/forensic-package.json output/reports/SOUTHERN_SPEAR_VESSEL_STRIKES_FIRST_PASS.md",
    "report:all": "pnpm report:pilot && pnpm report:kirk && pnpm report:good && pnpm report:vessels",
    "brief:setup": "python3 -m venv .venv && .venv/bin/python -m pip install -r scripts/requirements-docs.txt",
    "brief:kirk": ".venv/bin/python scripts/export-case-brief.py",
    "brief:good": ".venv/bin/python scripts/export-renee-good-brief.py",
    "brief:vessels": ".venv/bin/python scripts/export-southern-spear-brief.py",
    "brief:v2:apollo": ".venv/bin/python scripts/reporting/export-brief-v2.py fixtures/pilots/apollo-11-landing/forensic-package.json output/pdf/APOLLO_11_LANDING_AUDIT.pdf",
    "brief:v2:kirk": ".venv/bin/python scripts/reporting/export-brief-v2.py fixtures/pilots/charlie-kirk-assassination/forensic-package.json output/pdf/CHARLIE_KIRK_ASSASSINATION_FIRST_PASS.pdf",
    "brief:v2:good": ".venv/bin/python scripts/reporting/export-brief-v2.py fixtures/pilots/renee-good-killing/forensic-package.json output/pdf/RENEE_GOOD_KILLING_FIRST_PASS.pdf",
    "brief:v2:vessels": ".venv/bin/python scripts/reporting/export-brief-v2.py fixtures/pilots/southern-spear-vessel-strikes/forensic-package.json output/pdf/SOUTHERN_SPEAR_VESSEL_STRIKES_FIRST_PASS.pdf",
    "brief:v2:all": "pnpm brief:v2:apollo && pnpm brief:v2:kirk && pnpm brief:v2:good && pnpm brief:v2:vessels",
    "spatial:benchmark": "python3 scripts/spatial/generate_controlled_benchmark.py && node scripts/spatial/run-colmap-benchmark.mjs",
    "output:sync": "node scripts/sync-public-outputs.mjs",
    "cases:rebuild": "pnpm fixture:all && pnpm manifest:sign:all && pnpm report:all && pnpm brief:v2:all && pnpm output:sync",
    "verify": "pnpm typecheck && pnpm test && pnpm audit:package && pnpm audit:kirk && pnpm audit:good && pnpm audit:vessels && pnpm manifest:verify:all && pnpm source:check && pnpm source:kirk && pnpm source:good && pnpm source:vessels && pnpm build"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
