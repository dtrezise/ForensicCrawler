        "createdAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "auditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "investigationId", "sequence", "eventType", "actorType", "actorId", "occurredAt", "subjectIds", "details", "previousHash", "eventHash", "createdAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "investigationId": { "$ref": "#/$defs/id" },
        "sequence": { "type": "integer", "minimum": 1 },
        "eventType": { "type": "string", "minLength": 1 },
        "actorType": { "enum": ["human_role", "local_tool", "service_identity"] },
        "actorId": { "type": "string", "minLength": 1 },
        "occurredAt": { "$ref": "#/$defs/timestamp" },
        "subjectIds": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "details": { "type": "object" },
        "previousHash": { "oneOf": [{ "$ref": "#/$defs/hash" }, { "type": "null" }] },
        "eventHash": { "$ref": "#/$defs/hash" },
        "createdAt": { "$ref": "#/$defs/timestamp" }
      }
    }
  }
}
